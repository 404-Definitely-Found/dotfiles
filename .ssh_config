Host pi4
  HostName 100.80.40.44
  User chnmtrvd
  IdentityFile ~/.ssh/pi_key
  AddKeysToAgent yes
  LocalForward 10043 localhost:10043
  ExitOnForwardFailure no
  PermitLocalCommand yes
  LocalCommand kill $(cat /tmp/cp_listener.pid 2>/dev/null) 2>/dev/null; sleep 0.5; true

Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/testkey